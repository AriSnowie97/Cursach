@page "/profile"
@using FreelancePlatform.Client
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="container mt-4">
    <div class="card shadow-sm p-4">
        <h2>Мій профіль</h2>
        <hr />
        <div class="user-info">
            <p><strong>Ім'я:</strong> @UserState.Name @UserState.LastName</p>
            <p><strong>Роль:</strong> @UserState.Role</p>
        </div>

        <div class="mt-5 border-top pt-3">
            @* При кліку викликаємо HandleLogout *@
            <button class="btn btn-outline-danger" @onclick="HandleLogout">
                🚪 Вийти з акаунту
            </button>
        </div>
    </div>
</div>

@code {
    private async Task HandleLogout()
    {
        // ВИКЛИКАЄМО ОЧИСТКУ LOCAL STORAGE:
        await UserState.ClearSession(JS);
        
        // Повертаємося на головну
        Navigation.NavigateTo("/");
    }
}