@page "/login"
@using FreelancePlatform.Client
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="container mt-5">
    <div class="card shadow p-4 mx-auto" style="max-width: 400px;">
        <h3 class="text-center">Вхід</h3>
        <div class="mb-3">
            <label>Email:</label>
            <input type="email" class="form-control" @bind="loginModel.Email" />
        </div>
        <div class="mb-3">
            <label>Пароль:</label>
            <input type="password" class="form-control" @bind="loginModel.Password" />
        </div>
        <button class="btn btn-primary w-100" @onclick="HandleLogin">Увійти</button>
    </div>
</div>

@code {
    private LoginRequest loginModel = new LoginRequest();

    private async Task HandleLogin()
    {
        // Відправляємо дані на бекенд
        var response = await Http.PostAsJsonAsync("https://cursach-production.up.railway.app/api/auth/login", loginModel);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

            if (result != null)
            {
                // ОСЬ ТУТ МИ ВИКЛИКАЄМО НОВИЙ МЕТОД З UserState:
                await UserState.SaveSession(JS, result.Name, result.LastName, result.Role);
                
                // Переходимо на головну
                Navigation.NavigateTo("/");
            }
        }
    }

    public class LoginRequest { public string Email { get; set; } = ""; public string Password { get; set; } = ""; }
    public class LoginResponse { public string Name { get; set; } = ""; public string LastName { get; set; } = ""; public string Role { get; set; } = ""; }
}