@page "/create-order"
@using FreelancePlatform.Client
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Створити замовлення — Біржа</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4">Створити нове замовлення 📝</h2>

    @if (!UserState.IsLoggedIn || UserState.Role != "Customer")
    {
        <div class="alert alert-warning">
            Ця сторінка доступна лише для Замовників. Будь ласка, увійдіть під відповідним акаунтом.
        </div>
    }
    else
    {
        <div class="card shadow-sm p-4" style="max-width: 600px;">
            <div class="mb-3">
                <label class="form-label fw-bold">Назва проєкту:</label>
                <input type="text" class="form-control" @bind="newOrder.Title" placeholder="Наприклад: Зробити дизайн лендінгу" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Опис завдання:</label>
                <textarea class="form-control" rows="5" @bind="newOrder.Description" placeholder="Опишіть деталі, вимоги та терміни..."></textarea>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Бюджет ($):</label>
                <input type="number" class="form-control" @bind="newOrder.Budget" />
            </div>

            <button class="btn btn-primary w-100" @onclick="SubmitOrder">
                🚀 Опублікувати замовлення
            </button>
            
            @if (showError)
            {
                <div class="alert alert-danger mt-3">Сталася помилка при збереженні. Перевірте консоль (F12).</div>
            }
        </div>
    }
</div>

@code {
    private OrderModel newOrder = new OrderModel();
    private bool showError = false;

    private async Task SubmitOrder()
    {
        try
        {
            // Відправляємо дані на наш новий контролер
            var response = await Http.PostAsJsonAsync("https://cursach-production.up.railway.app/api/orders", newOrder);
            
            if (response.IsSuccessStatusCode)
            {
                // Якщо все добре, перекидаємо користувача на головну сторінку
                Navigation.NavigateTo("/");
            }
            else
            {
                showError = true;
            }
        }
        catch
        {
            showError = true;
        }
    }

    // Модель даних (має збігатися з моделлю на бекенді!)
    public class OrderModel
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Budget { get; set; } // УВАГА: якщо в БД у тебе Budget, зміни тут Price на Budget!
    }
}