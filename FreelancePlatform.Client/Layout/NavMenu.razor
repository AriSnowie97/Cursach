@using FreelancePlatform.Client
@implements IDisposable
@inject NavigationManager Navigation
@inject IJSRuntime JS

<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm py-2">
    <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center text-dark" href="">
            <span class="fs-4 me-2">🚀</span> 
            <span style="letter-spacing: 1px;">ФРІЛАНС.ЮА</span>
        </a>

        <div class="d-flex align-items-center ms-auto">
            <div class="navbar-nav d-flex flex-row align-items-center gap-2">
                
                <NavLink class="nav-link px-3 py-2 text-dark" href="" Match="NavLinkMatch.All">Всі замовлення</NavLink>

                @if (UserState.IsLoggedIn)
                {
                    if (UserState.Role == "Customer")
                    {
                        <NavLink class="nav-link px-3 py-2 text-dark" href="create-order">Створити замовлення</NavLink>
                    }
                    else if (UserState.Role == "Freelancer")
                    {
                        <NavLink class="nav-link px-3 py-2 text-dark" href="my-proposals">Мої пропозиції</NavLink>
                    }

                    <div class="nav-item ms-lg-3">
                        <NavLink class="btn btn-primary rounded-pill px-4" href="profile" style="line-height: 1.5;">
                            👋 @UserState.Name
                        </NavLink>
                    </div>
                }
                else
                {
                    <NavLink class="nav-link px-3 py-2 text-dark" href="login">Вхід</NavLink>
                    <div class="nav-item ms-lg-2">
                        <NavLink class="btn btn-outline-primary rounded-pill px-4" href="register" style="line-height: 1.5;">
                            Реєстрація
                        </NavLink>
                    </div>
                }
            </div>
        </div>
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        UserState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        UserState.OnChange -= StateHasChanged;
    }
}