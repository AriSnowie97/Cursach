@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="d-flex flex-column min-vh-100">
    @* Тепер меню буде красивою полосою зверху *@
    <NavMenu /> 

    @* Основний контент сайту на сірому тлі *@
    <main class="flex-grow-1 bg-light pt-4 pb-5">
        <article class="container">
            @if (isInitialized)
            {
                @Body
            }
            else
            {
                <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ms-2">Завантаження профілю...</span>
                </div>
            }
        </article>
    </main>
</div>

@code {
    private bool isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Ждем, пока UserState достанет данные из памяти браузера
            await UserState.LoadSession(JS);
            
            // Теперь мы готовы показывать страницу
            isInitialized = true;
            StateHasChanged();
        }
    }
}