@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="d-flex flex-column min-vh-100 bg-light">
    <NavMenu /> 

    <main class="flex-grow-1">
        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-12 col-xl-10">
                    @if (isInitialized)
                    {
                        @Body
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-3 text-muted">Завантаження даних...</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>

    <footer class="bg-white border-top py-4 text-center text-muted">
        <div class="container">
            &copy; 2026 Біржа Фрілансу — Дизайн та розробка
        </div>
    </footer>
</div>

@code {
    private bool isInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Ждем, пока UserState достанет данные из памяти браузера
            await UserState.LoadSession(JS);
            
            // Теперь мы готовы показывать страницу
            isInitialized = true;
            StateHasChanged();
        }
    }
}